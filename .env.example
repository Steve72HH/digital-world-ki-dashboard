PORT=8787
DATA_DIR=./data

# mock | ollama | openai-compatible
# mock ist der sichere Default fuer neue Installationen.
AI_PROVIDER=mock
AI_MODEL=gpt-4.1-mini

# OpenAI-compatible Beispiel:
# AI_PROVIDER=openai-compatible
# AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=

# Ollama Beispiel:
# AI_PROVIDER=ollama
# AI_BASE_URL=http://localhost:11434
# AI_MODEL=llama3.2:1b

# Hinweis:
# Provider-Keys und Workflow-Webhooks koennen auch im Dashboard gepflegt werden.
# Echte Keys niemals committen.
